(version 1)
(rule "Same Footprint Pad Clearance"
  (constraint clearance (min 0.0mm))
  (condition "A.Type == 'pad' && B.Type == 'pad' && A.Parent.Reference == B.Parent.Reference"))

(rule "Same Footprint Hole Clearance"
  (constraint hole_clearance (min 0.0mm))
  (condition "A.Type == 'pad' && B.Type == 'pad' && A.Parent.Reference == B.Parent.Reference"))